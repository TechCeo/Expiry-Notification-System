APP_NAME=Expiry Notification API
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

POSTGRES_DB=expiry_notification
POSTGRES_USER=expiry_app
POSTGRES_PASSWORD=change-me-before-production
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://expiry_app:change-me-before-production@db:5432/expiry_notification
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30

# Configure these values for your OIDC provider. The API validates signed access tokens
# and never stores user passwords.
OIDC_ISSUER_URL=https://your-identity-provider.example.com/
OIDC_AUDIENCE=expiry-notification-api
OIDC_JWKS_URL=https://your-identity-provider.example.com/.well-known/jwks.json
OIDC_ALGORITHMS=RS256
OIDC_JWKS_CACHE_SECONDS=300
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_AUTH_MODE=oidc
VITE_OIDC_AUTHORITY=https://identity.example.invalid/
VITE_OIDC_CLIENT_ID=expiry-notification-web
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
VITE_OIDC_SCOPE=openid profile email

# Optional local-only workaround for intercepted TLS certificates during image builds.
# Prefer installing your organization's root CA instead of using these.
PIP_TRUSTED_HOST=
NPM_CONFIG_STRICT_SSL=true
